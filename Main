import asyncio
import logging
from datetime import datetime, timedelta
from typing import Dict, Optional

from telegram import ChatPermissions, Update
from telegram.constants import ParseMode
from telegram.ext import (
    Application,
    CommandHandler,
    MessageHandler,
    filters,
    ContextTypes,
    ConversationHandler,
)

# Включим логирование
logging.basicConfig(
    format="%(asctime)s - %(name)s - %(levelname)s - %(message)s", level=logging.INFO
)
logger = logging.getLogger(__name__)

# Состояния для ConversationHandler
WAITING_FOR_MUTE_DURATION = 1

# Хранилище для временных данных (в реальном проекте используйте БД)
user_data_temp: Dict[int, dict] = {}


async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Приветственное сообщение."""
    await update.message.reply_text(
        "👋 Привет! Я бот для мута пользователей.\n\n"
        "Команды:\n"
        "/mute - замутить пользователя (ответь на его сообщение)\n"
        "/unmute - размутить пользователя (ответь на его сообщение)\n\n"
        "⚠️ Только администраторы могут использовать эти команды."
    )


async def mute_command(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """
    Обработчик команды /mute.
    Проверяет права и начинает диалог для указания времени.
    """
    chat = update.effective_chat
    user = update.effective_user
    reply_to_message = update.message.reply_to_message

    # Проверяем, что команда вызвана в группе/супергруппе
    if chat.type not in ["group", "supergroup"]:
        await update.message.reply_text("❌ Эта команда работает только в группах.")
        return ConversationHandler.END

    # Проверяем, что бот админ
    bot_member = await chat.get_member(context.bot.id)
    if not bot_member.can_restrict_members:
        await update.message.reply_text(
            "❌ У меня нет прав на ограничение участников. "
            "Пожалуйста, дайте мне права администратора с правом 'Блокировка пользователей'."
        )
        return ConversationHandler.END

    # Проверяем, что команда вызвана с ответом на сообщение
    if not reply_to_message:
        await update.message.reply_text(
            "❌ Чтобы замутить пользователя, ответьте на его сообщение командой /mute."
        )
        return ConversationHandler.END

    target_user = reply_to_message.from_user
    admin_user = user

    # Проверяем, что вызывающий админ
    caller_member = await chat.get_member(admin_user.id)
    if not caller_member.can_restrict_members:
        await update.message.reply_text("❌ У вас нет прав на ограничение участников.")
        return ConversationHandler.END

    # Проверяем, что цель не админ
    target_member = await chat.get_member(target_user.id)
    if target_member.status in ["administrator", "creator"]:
        await update.message.reply_text(
            "❌ Нельзя замутить администратора или создателя чата."
        )
        return ConversationHandler.END

    # Сохраняем данные для следующего шага
    user_data_temp[user.id] = {
        "target_user_id": target_user.id,
        "target_user_name": target_user.full_name,
        "chat_id": chat.id,
    }

    # Запрашиваем время мута
    await update.message.reply_text(
        f"⏰ На какое время замутить {target_user.full_name}?\n"
        f"Введите количество минут (целое число, больше 0):"
    )

    return WAITING_FOR_MUTE_DURATION


async def handle_mute_duration(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """
    Обрабатывает ввод времени мута.
    """
    user = update.effective_user
    text = update.message.text.strip()

    # Проверяем, что введено число
    try:
        minutes = int(text)
        if minutes <= 0:
            raise ValueError("Время должно быть больше 0")
    except ValueError:
        await update.message.reply_text(
            "❌ Пожалуйста, введите целое положительное число (количество минут).\n"
            "Попробуйте снова:"
        )
        return WAITING_FOR_MUTE_DURATION

    # Получаем сохранённые данные
    temp_data = user_data_temp.get(user.id)
    if not temp_data:
        await update.message.reply_text(
            "❌ Произошла ошибка. Пожалуйста, используйте /mute заново."
        )
        return ConversationHandler.END

    target_user_id = temp_data["target_user_id"]
    target_user_name = temp_data["target_user_name"]
    chat_id = temp_data["chat_id"]

    # Удаляем временные данные
    del user_data_temp[user.id]

    try:
        chat = update.effective_chat
        target_member = await chat.get_member(target_user_id)

        # Вычисляем время окончания мута
        until_date = datetime.now() + timedelta(minutes=minutes)

        # Меняем права: отключаем возможность писать
        await chat.restrict_member(
            user_id=target_user_id,
            permissions=ChatPermissions(
                can_send_messages=False,
                can_send_media_messages=False,
                can_send_other_messages=False,
                can_add_web_page_previews=False,
            ),
            until_date=until_date,
        )

        # Уведомляем о муте
        await update.message.reply_text(
            f"✅ Пользователь {target_user_name} замьючен на {minutes} минут(ы).\n"
            f"⏰ Мут истечёт: {until_date.strftime('%d.%m.%Y %H:%M:%S')}"
        )

        logger.info(
            f"User {target_user_name} (ID: {target_user_id}) muted in chat {chat_id} "
            f"by {user.full_name} for {minutes} minutes"
        )

    except Exception as e:
        await update.message.reply_text(f"❌ Ошибка при муте: {str(e)}")
        logger.error(f"Error muting user: {e}")

    return ConversationHandler.END


async def unmute_command(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """
    Размучивает пользователя, на чьё сообщение ответили.
    """
    chat = update.effective_chat
    user = update.effective_user
    reply_to_message = update.message.reply_to_message

    # Проверяем, что команда вызвана в группе/супергруппе
    if chat.type not in ["group", "supergroup"]:
        await update.message.reply_text("❌ Эта команда работает только в группах.")
        return

    # Проверяем, что бот админ
    bot_member = await chat.get_member(context.bot.id)
    if not bot_member.can_restrict_members:
        await update.message.reply_text(
            "❌ У меня нет прав на ограничение участников."
        )
        return

    # Проверяем, что команда вызвана с ответом на сообщение
    if not reply_to_message:
        await update.message.reply_text(
            "❌ Чтобы размутить пользователя, ответьте на его сообщение командой /unmute."
        )
        return

    target_user = reply_to_message.from_user
    admin_user = user

    # Проверяем, что вызывающий админ
    caller_member = await chat.get_member(admin_user.id)
    if not caller_member.can_restrict_members:
        await update.message.reply_text("❌ У вас нет прав на ограничение участников.")
        return

    # Проверяем, что цель не админ (для безопасности)
    target_member = await chat.get_member(target_user.id)
    if target_member.status in ["administrator", "creator"]:
        await update.message.reply_text(
            "❌ Нельзя изменять права администратора или создателя чата."
        )
        return

    try:
        # Снимаем все ограничения
        await chat.restrict_member(
            user_id=target_user.id,
            permissions=ChatPermissions(
                can_send_messages=True,
                can_send_media_messages=True,
                can_send_other_messages=True,
                can_add_web_page_previews=True,
            ),
        )

        await update.message.reply_text(
            f"✅ Пользователь {target_user.full_name} размучен."
        )

        logger.info(
            f"User {target_user.full_name} (ID: {target_user.id}) unmuted in chat {chat.id} "
            f"by {user.full_name}"
        )

    except Exception as e:
        await update.message.reply_text(f"❌ Ошибка при размуте: {str(e)}")
        logger.error(f"Error unmuting user: {e}")


async def cancel(update: Update, context: ContextTypes.DEFAULT_TYPE) -> int:
    """Отменяет диалог мута."""
    user = update.effective_user
    if user.id in user_data_temp:
        del user_data_temp[user.id]

    await update.message.reply_text("❌ Операция отменена.")
    return ConversationHandler.END


def main() -> None:
    """Запуск бота."""
    # Вставьте сюда ваш токен
    TOKEN = "YOUR_BOT_TOKEN_HERE"

    # Создаём приложение
    application = Application.builder().token(TOKEN).build()

    # Создаём ConversationHandler для мута
    mute_conv_handler = ConversationHandler(
        entry_points=[CommandHandler("mute", mute_command)],
        states={
            WAITING_FOR_MUTE_DURATION: [
                MessageHandler(filters.TEXT & ~filters.COMMAND, handle_mute_duration)
            ],
        },
        fallbacks=[CommandHandler("cancel", cancel)],
    )

    # Регистрируем обработчики
    application.add_handler(mute_conv
